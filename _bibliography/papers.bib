@phdthesis{dissertation,
  bibtex_show = {true},
  abbr        = {Thesis},
  author      = {Momeu, Marius},
  title       = {Retrofitting Operating System Security via Commodity Hardware Extensions},
  school      = {Technische Universität München},
  year        = {2026},
  pages       = {151},
  abstract    = {This thesis proposes hardening schemes that mitigate memory-safety errors in operating systems efficiently. We leverage recent hardware primitives for fine-grained memory isolation to design compartmentalization and heap hardening frameworks that thwart dangling pointers, type confusion, and arbitrary R/W, which are key exploitation capabilities. We evaluate our techniques on the Linux kernel. Lastly, we improve fuzzing for finding critical vulnerabilities in hypervisors.},
  pdf         = {https://mediatum.ub.tum.de/doc/1834845/1834845.pdf},
}
